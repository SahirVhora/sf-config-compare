# Security Notes
# 1. NEVER commit this file. It is already in .gitignore.
# 2. SESSION_COOKIE_SECURE must be 'true' in production (HTTPS) or cookies are sent over plain HTTP.
# 3. Generate a strong SECRET_KEY in production. The default below is ONLY for local development.
# 4. If you expose this app on a network, set REPORT_ACCESS_TOKEN to prevent unauthorized report access.
# 5. Rotate credentials immediately if .secrets.json was ever committed to version control.

[TEMPLATE]
# Flask session signing key (either name works; SECRET_KEY takes precedence)
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Do NOT use the placeholder in production.
SECRET_KEY=change-me-to-a-random-secret
# FLASK_SECRET_KEY=alternate-secret-key-name

LOG_LEVEL=INFO

# Production hardening
SESSION_COOKIE_SECURE=false

# Required in production: restrict report access to requests bearing this token
# REPORT_ACCESS_TOKEN=your-shared-secret
