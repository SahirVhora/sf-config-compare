# Flask session signing key (either name works; SECRET_KEY takes precedence)
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret
# FLASK_SECRET_KEY=alternate-secret-key-name

LOG_LEVEL=INFO

# Optional: restrict report access to requests bearing this token
# REPORT_ACCESS_TOKEN=your-shared-secret
